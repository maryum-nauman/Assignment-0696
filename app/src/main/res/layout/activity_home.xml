<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:id="@+id/main">

    <ImageView
        android:layout_width="200dp"
        android:layout_height="80dp"
        android:id="@+id/ivlogo"
        android:src="@drawable/cinefast"
        android:layout_marginLeft="12dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvSelectDate"
        android:textSize="18sp"
        android:text="Select Date"
        android:textColor="#AAAAAA"
        android:layout_below="@id/ivlogo"
        android:layout_marginTop="12dp"
        android:layout_marginLeft="12dp"/>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/layoutdates"
        android:layout_below="@id/tvSelectDate"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="12dp">
        <Button
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:id="@+id/btnToday"
            android:text="Today"
            android:textColor="@color/white"
            android:backgroundTint="#e5000e"/>
        <Button
            android:layout_width="150dp"
            android:layout_height="40dp"
            android:id="@+id/btnTomorrow"
            android:text="Tomorrow"
            android:layout_marginStart="10dp"
            android:textColor="@color/white"
            android:backgroundTint="#555555"/>

    </LinearLayout>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvNowShowing"
        android:text="Now Showing"
        android:textSize="24sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_below="@id/layoutdates"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/movie1"
        android:layout_below="@id/tvNowShowing"
        android:layout_marginTop="12dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:background="@drawable/card_background"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="140dp"
            android:id="@+id/darkknight"
            android:src="@drawable/thedarkknight"
            android:layout_marginLeft="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvdarkknight"
                android:text="The Dark Knight"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvdktime"
                android:text="Action / 152 min"
                android:textSize="18sp"
                android:textColor="#555555"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:layout_width="150dp"
                    android:layout_height="50dp"
                    android:id="@+id/btnbookDK"
                    android:backgroundTint="#FF0000"
                    android:text="Book Seats"
                    android:textColor="@color/white"
                    app:cornerRadius="10dp"
                    android:layout_marginTop="16dp"/>
                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"/>
                <Button
                    android:layout_width="120dp"
                    android:layout_height="50dp"
                    android:id="@+id/trailerDK"
                    android:backgroundTint="@color/white"
                    android:text="Trailer"
                    android:textColor="@color/black"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/movie2"
        android:layout_below="@id/movie1"
        android:layout_marginTop="12dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:background="@drawable/card_background"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="140dp"
            android:id="@+id/inception"
            android:src="@drawable/inception"
            android:layout_marginLeft="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvinception"
                android:text="Inception"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvinceptiontime"
                android:text="Sci-Fi / 148 min"
                android:textSize="18sp"
                android:textColor="#555555"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
            <Button
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:id="@+id/btnbookIP"
                android:backgroundTint="#FF0000"
                android:text="Book Seats"
                android:textColor="@color/white"
                app:cornerRadius="10dp"
                android:layout_marginTop="16dp"/>
                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"/>
                <Button
                    android:layout_width="120dp"
                    android:layout_height="50dp"
                    android:id="@+id/trailerIP"
                    android:backgroundTint="@color/white"
                    android:text="Trailer"
                    android:textColor="@color/black"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/movie3"
        android:layout_below="@id/movie2"
        android:layout_marginTop="12dp"
        android:layout_marginRight="10dp"
        android:layout_marginLeft="10dp"
        android:background="@drawable/card_background"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="140dp"
            android:id="@+id/interstellar"
            android:src="@drawable/interstellar"
            android:layout_marginLeft="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvinterstellar"
                android:text="Interstellar"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvinterstellartime"
                android:text="Sci-Fi / 169 min"
                android:textSize="18sp"
                android:textColor="#555555"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
            <Button
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:id="@+id/btnbookIS"
                android:backgroundTint="#FF0000"
                android:text="Book Seats"
                android:textColor="@color/white"
                app:cornerRadius="10dp"
                android:layout_marginTop="16dp"/>
                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"/>
                <Button
                    android:layout_width="120dp"
                    android:layout_height="50dp"
                    android:id="@+id/trailerIS"
                    android:backgroundTint="@color/white"
                    android:text="Trailer"
                    android:textColor="@color/black"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/movie4"
        android:layout_below="@id/movie3"
        android:layout_marginTop="12dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:background="@drawable/card_background"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="140dp"
            android:id="@+id/ssr"
            android:src="@drawable/theshawshankredemption"
            android:layout_marginLeft="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvSSR"
                android:text="The Shawshank Redemption"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvSSRtime"
                android:text="Drama / 142 min"
                android:textSize="18sp"
                android:textColor="#555555"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
            <Button
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:id="@+id/btnbookSSR"
                android:backgroundTint="#FF0000"
                android:text="Book Seats"
                android:textColor="@color/white"
                app:cornerRadius="10dp"
                android:layout_marginTop="16dp"/>
                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"/>
                <Button
                    android:layout_width="120dp"
                    android:layout_height="50dp"
                    android:id="@+id/trailerSSR"
                    android:backgroundTint="@color/white"
                    android:text="Trailer"
                    android:textColor="@color/black"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>


</RelativeLayout>