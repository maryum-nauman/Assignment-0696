<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#c4c4c4">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="16dp"
        android:src="@drawable/backbutton"/>

    <TextView
        android:id="@+id/tvmoviename"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Movie Name"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"/>

    <TextView
        android:id="@+id/tvscreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Screen X"
        android:layout_below="@id/tvmoviename"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:textColor="@color/white"
        android:textSize="18sp"/>

    <LinearLayout
        android:id="@+id/linear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="45dp"
        android:layout_marginLeft="16dp"
        android:layout_below="@id/tvscreen">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Theater" android:textSize="14sp" android:textColor="#555555"/>
        <View android:layout_width="100dp" android:layout_height="40dp"/>
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Hall" android:textSize="14sp" android:textColor="#555555"/>
        <View android:layout_width="40dp" android:layout_height="40dp"/>
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Date" android:textSize="14sp" android:textColor="#555555"/>
        <View android:layout_width="55dp" android:layout_height="40dp"/>
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Time" android:textSize="14sp" android:textColor="#555555"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/linear2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/linear"
        android:layout_marginLeft="16dp"
        android:orientation="horizontal">

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/tvTheatre" android:text="Stars (90 Mall)" android:textSize="16sp" android:textColor="@color/white"/>
        <View android:layout_width="35dp" android:layout_height="35dp"/>
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/tvHall" android:text="Hall" android:textSize="16sp" android:textColor="@color/white"/>
        <View android:layout_width="35dp" android:layout_height="35dp"/>
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/tvDate" android:text="Date" android:textSize="16sp" android:textColor="@color/white"/>
        <View android:layout_width="30dp" android:layout_height="30dp"/>
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/tvTime" android:text="Time" android:textSize="16sp" android:textColor="@color/white"/>

    </LinearLayout>

    <!-- SCROLLABLE SECTION -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/linear2"
        android:layout_marginTop="20dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#000000"
            android:gravity="center_horizontal">

            <!-- SCREEN -->
            <ImageView
                android:id="@+id/ivscreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/screen"
                android:layout_marginTop="40dp"/>

            <!-- SEATS -->
            <LinearLayout
                android:id="@+id/linear3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"/>

            <!-- LEGEND IMAGE BELOW SEATS -->
            <ImageView
                android:layout_width="400dp"
                android:layout_height="80dp"
                android:src="@drawable/seatstatus"
                android:layout_marginTop="20dp"/>

            <!-- BUTTONS BELOW EVERYTHING -->
            <LinearLayout
                android:id="@+id/linear4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btnBookTickets"
                    android:layout_width="160dp"
                    android:layout_height="60dp"
                    android:text="Book Tickets"
                    android:textColor="@color/white"
                    android:backgroundTint="#e5000e"/>

                <Button
                    android:id="@+id/btnProceed"
                    android:layout_width="200dp"
                    android:layout_height="60dp"
                    android:text="Proceed To Snacks"
                    android:layout_marginStart="10dp"
                    android:textColor="@color/black"
                    android:backgroundTint="@color/white"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>
